		{
			"name": "Admin — Resources CRUD",
			"description": "Dynamic resource CRUD. Requires Bearer token + admin access + manageContent permission.\n\nValid types: services, announcements, press-releases, agencies, agency-groups, leaders, departments, chambers, recent-laws, courts, judiciary-functions, hero-settings",
